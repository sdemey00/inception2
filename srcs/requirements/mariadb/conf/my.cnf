[mysqld]
# Listen on all interfaces so WordPress container can connect
bind-address = 0.0.0.0
port = 3306

# Data directory
datadir = /var/lib/mysql

# Disable DNS lookups for performance in containers
skip-name-resolve

[client]
default-character-set = utf8mb4

[mysqld_safe]
log-error = /var/log/mysql/error.log
pid-file = /var/run/mysqld/mysqld.pid